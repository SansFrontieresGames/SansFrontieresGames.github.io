---
import '../styles/global.css'
import Footer from '../components/Footer.astro'

const { title = 'Sans Frontieres' } = Astro.props
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Sans Frontieres — Independent game studio crafting immersive story-driven experiences." />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Sans Frontieres — Independent game studio crafting immersive story-driven experiences." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cinzel+Decorative:wght@700&display=swap" rel="stylesheet">
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <slot />
    <Footer />

    <script src="/scripts/navbar.js" defer></script>
  </body>
</html>
