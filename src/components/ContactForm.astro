<div class="contact-form-wrap">
  <div class="form-bg-pulse" aria-hidden="true"></div>

  <form data-contact-form novalidate>
    <div style="position:absolute;left:-9999px;top:-9999px" aria-hidden="true">
      <label for="website">Website</label>
      <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
    </div>

    <label for="nombre">Nombre</label>
    <input id="nombre" type="text" name="nombre" placeholder="Tu nombre" required aria-required="true" aria-describedby="nombre-error" />
    <span id="nombre-error" class="field-error" role="alert"></span>

    <label for="email">Correo</label>
    <input id="email" type="email" name="email" placeholder="tu@email.com" required aria-required="true" aria-describedby="email-error" />
    <span id="email-error" class="field-error" role="alert"></span>

    <label for="mensaje">Mensaje</label>
    <textarea id="mensaje" name="mensaje" rows="6" placeholder="Escribe tu mensaje..." required aria-required="true" aria-describedby="mensaje-error"></textarea>
    <span id="mensaje-error" class="field-error" role="alert"></span>

    <button type="submit">Enviar</button>

    <div class="form-message" role="status" aria-live="polite" data-form-message></div>
  </form>
</div>

<script>
  const form = document.querySelector('[data-contact-form]')
  const messageEl = document.querySelector('[data-form-message]')

  if (!form || !messageEl) {
    console.warn('ContactForm: required elements not found')
  } else {

    function clearErrors() {
      form.querySelectorAll('.field-error').forEach(el => el.textContent = '')
    }

    function showErrors() {
      form.querySelectorAll(':invalid').forEach(field => {
        const describedBy = field.getAttribute('aria-describedby')
        if (describedBy) {
          const errorEl = document.getElementById(describedBy)
          if (errorEl) errorEl.textContent = field.validationMessage
        }
      })
    }

    form.addEventListener('input', (e) => {
      const field = e.target
      if (field.checkValidity()) {
        const describedBy = field.getAttribute('aria-describedby')
        if (describedBy) {
          const errorEl = document.getElementById(describedBy)
          if (errorEl) errorEl.textContent = ''
        }
      }
    })

    form.addEventListener('submit', (e) => {
      e.preventDefault()
      clearErrors()

      const honeypot = form.querySelector('[name="website"]')
      if (honeypot && honeypot.value) return

      if (!form.checkValidity()) {
        showErrors()
        const firstInvalid = form.querySelector(':invalid')
        if (firstInvalid) firstInvalid.focus()
        return
      }

      messageEl.textContent = '\u2705 Mensaje enviado (demo).'
      messageEl.classList.add('visible')

      form.reset()

      setTimeout(() => {
        messageEl.classList.remove('visible')
      }, 2500)
    })
  }
</script>
