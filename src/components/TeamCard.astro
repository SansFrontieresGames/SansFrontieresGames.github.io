---
interface Props {
  name: string
  role: string
  description: string
  image: string
  index?: number
}

const { name, role, description, image, index = 0 } = Astro.props
---

<article
  class="team-card"
  data-card
  style={`--card-i: ${index}`}
>
  <div class="card-bg-pulse" aria-hidden="true"></div>

  <div class="card-media">
    <img
      src={image}
      alt={name}
      loading="lazy"
      onerror="this.src='/img/placeholder.png'; this.onerror=null;"
    />
  </div>

  <div class="card-body">
    <h3>{name}</h3>
    <p class="card-role">{role}</p>
    <p class="card-desc">{description}</p>
  </div>
</article>
